# Database
DATABASE_URL="postgresql://user:password@localhost:5432/database_name"

# JWT - IMPORTANT: Generate a strong random secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="7d"

# Session (for OAuth state management)
# IMPORTANT: Generate a strong random secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="your-session-secret-change-in-production-make-it-very-long-and-random"

# App
PORT=3001
NODE_ENV=development

# Dev: Set to "true" to skip endTime validation when completing bookings (local dev only)
DEV_BYPASS_SESSION_TIME=true

# CORS (frontend URL)
FRONTEND_URL="http://localhost:3000"

# OAuth - Google
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# OAuth - Facebook
# Get credentials from: https://developers.facebook.com/apps
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"

# Email - Resend
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"

# Enterprise - admin notification email (where new lead notifications are sent)
ADMIN_EMAIL="burguntowy@gmail.com"

# Enterprise - default locale for email notifications
DEFAULT_LOCALE="pl"

# Enterprise - CLI approve secret
# Used by: npm run enterprise:approve <leadId>
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APPROVE_SECRET="your-approve-secret-change-this-in-production"

# Development - set to "true" to bypass session endTime check for completing bookings
DEV_BYPASS_SESSION_TIME="true"

# Cloudflare R2 (S3-compatible object storage)
# Get credentials from: https://dash.cloudflare.com → R2 → Account API Tokens
R2_ENDPOINT="https://ACCOUNT_ID.r2.cloudflarestorage.com"
R2_ACCESS_KEY_ID="your-access-key-id"
R2_SECRET_ACCESS_KEY="your-secret-access-key"
R2_BUCKET="exercio-uploads"
R2_REGION="auto"
# Optional: public URL for serving files (e.g., if you set up a custom domain)
R2_PUBLIC_URL=""

# API base URL - used to construct full URLs for uploaded files served via the proxy
# In production: https://api.exercio.app
# In development: http://localhost:3001
API_BASE_URL="http://localhost:3001"
