# Database
DATABASE_URL="postgresql://user:password@localhost:5432/database_name"

# JWT - IMPORTANT: Generate a strong random secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRATION="7d"

# Session (for OAuth state management)
# IMPORTANT: Generate a strong random secret for production!
# Use: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET="your-session-secret-change-in-production-make-it-very-long-and-random"

# App
PORT=3001
NODE_ENV=development

# CORS (frontend URL)
FRONTEND_URL="http://localhost:3000"

# OAuth - Google
# Get credentials from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_CALLBACK_URL="http://localhost:3001/auth/google/callback"

# OAuth - Facebook
# Get credentials from: https://developers.facebook.com/apps
FACEBOOK_APP_ID="your-facebook-app-id"
FACEBOOK_APP_SECRET="your-facebook-app-secret"
FACEBOOK_CALLBACK_URL="http://localhost:3001/auth/facebook/callback"

# Email - Resend
# Get API key from: https://resend.com/api-keys
RESEND_API_KEY="re_your_api_key_here"
