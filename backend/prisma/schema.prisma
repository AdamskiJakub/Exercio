generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  password             String?            // bcrypt hashed - optional for OAuth users
  username             String             @unique
  role                 UserRole           @default(CLIENT)
  firstName            String?
  lastName             String?
  phone                String?
  provider             String             @default("local") // "local" | "google" | "facebook" | "apple"
  providerId           String?            // OAuth provider user ID
  isEmailVerified      Boolean            @default(false)   // Auto-true for OAuth
  avatarUrl            String?            // Profile picture from OAuth provider
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  instructorProfile    InstructorProfile?
  bookingsAsClient     Booking[]          @relation("ClientBookings")
  bookingsAsInstructor Booking[]          @relation("InstructorBookings")
  reviews              Review[]

  @@unique([provider, providerId])
  @@map("users")
}

model InstructorProfile {
  id                      String                  @id @default(uuid())
  userId                  String                  @unique
  bio                     String?
  specializations         String[]
  location                String?
  city                    String?
  hourlyRate              Float?
  photoUrl                String?
  verified                Boolean                 @default(false)
  yearsExperience         Int?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  availability            String?
  gallery                 String[]
  goals                   String[]
  languages               String[]
  tagline                 String?
  tags                    String[]
  isDraft                 Boolean                 @default(true)
  packageDealsDescription String?
  packageDealsEnabled     Boolean                 @default(false)
  hourlyRateHidden        Boolean                 @default(false)
  contactMessage          String?
  showEmail               Boolean                 @default(false)
  showPhone               Boolean                 @default(false)
  isBookingEnabled        Boolean                 @default(false)
  minNoticeHours          Int                     @default(48)
  sessionDuration         Int                     @default(60)
  sessionPrice            Float?
  paymentInfo             String?
  paymentMethods          String[]                @default([])
  weeklyAvailability      Availability[]          @relation("WeeklyAvailability")
  availabilityExceptions  AvailabilityException[] @relation("AvailabilityExceptions")
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  services                Service[]

  @@map("instructor_profiles")
}

model Service {
  id           String            @id @default(uuid())
  instructorId String
  name         String
  description  String?
  price        Float
  duration     Int
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  bookings     Booking[]
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@map("services")
}

model Booking {
  id                         String        @id @default(uuid())
  clientId                   String?
  instructorId               String
  serviceId                  String?
  date                       DateTime?
  status                     BookingStatus @default(PENDING)
  notes                      String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  cancellationReason         String?
  cancelledAt                DateTime?
  cancelledBy                String?
  duration                   Int?
  endTime                    DateTime?
  isManualBlock              Boolean       @default(false)
  isShortNotice              Boolean       @default(false)
  price                      Float?
  startTime                  DateTime?
  guestEmail                 String?
  guestName                  String?
  guestPhone                 String?
  acknowledgedAt             DateTime?
  hiddenFromClient           Boolean       @default(false)
  
  // NOWE ZMIENNE Z TOKENAMI:
  cancellationToken          String?       @unique
  cancellationTokenExpiresAt DateTime?
  
  client                     User?         @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  instructorUser             User          @relation("InstructorBookings", fields: [instructorId], references: [id], onDelete: Cascade, map: "bookings_instructor_user_fkey")
  service                    Service?      @relation(fields: [serviceId], references: [id])
  review                     Review?

  @@index([clientId])
  @@index([instructorId])
  @@index([startTime])
  @@index([status])
  
  // NOWE INDEKSY DLA TOKENÓW:
  @@index([cancellationToken])
  @@index([cancellationTokenExpiresAt])
  @@map("bookings")
}

model Review {
  id        String   @id @default(uuid())
  bookingId String   @unique
  userId    String
  rating    Int
  comment   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  booking   Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id])

  @@map("reviews")
}

model Availability {
  id           String            @id @default(uuid())
  instructorId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   InstructorProfile @relation("WeeklyAvailability", fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, dayOfWeek])
  @@index([instructorId])
  @@map("availability")
}

model AvailabilityException {
  id           String            @id @default(uuid())
  instructorId String
  date         DateTime          @db.Date
  isAvailable  Boolean           @default(false)
  startTime    String?
  endTime      String?
  reason       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   InstructorProfile @relation("AvailabilityExceptions", fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, date])
  @@index([instructorId])
  @@index([date])
  @@map("availability_exceptions")
}

model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, type, used])
  @@map("verification_codes")
}

enum UserRole {
  CLIENT
  INSTRUCTOR
  ADMIN
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}
