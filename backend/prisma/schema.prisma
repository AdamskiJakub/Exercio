generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                   String             @id @default(uuid())
  email                String             @unique
  password             String?            // bcrypt hashed - optional for OAuth users
  username             String             @unique
  role                 UserRole           @default(CLIENT)
  firstName            String?
  lastName             String?
  phone                String?
  provider             String             @default("local") // "local" | "google" | "facebook" | "apple"
  providerId           String?            // OAuth provider user ID
  isEmailVerified      Boolean            @default(false)   // Auto-true for OAuth
  avatarUrl            String?            // Profile picture from OAuth provider
  activationToken      String?            @unique // Token for enterprise account activation
  activationExpires    DateTime?          // Expiry for activation token
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  instructorProfile    InstructorProfile?
  enterpriseProfile    EnterpriseProfile?                 // 1:1 for Enterprise
  bookingsAsClient     Booking[]          @relation("ClientBookings")
  bookingsAsInstructor Booking[]          @relation("InstructorBookings")
  reviews              Review[]
  favorites            Favorite[]
  notifications        Notification[]
  profileViews         ProfileView[]
  enterpriseFollows    EnterpriseFollow[]

  @@unique([provider, providerId])
  @@map("users")
}

model InstructorProfile {
  id                      String                  @id @default(uuid())
  userId                  String                  @unique
  bio                     String?
  specializations         String[]
  location                String?
  city                    String?
  hourlyRate              Float?
  photoUrl                String?
  verified                Boolean                 @default(false)
  yearsExperience         Int?
  createdAt               DateTime                @default(now())
  updatedAt               DateTime                @updatedAt
  availability            String?
  gallery                 String[]
  goals                   String[]
  languages               String[]
  tagline                 String?
  tags                    String[]
  isDraft                 Boolean                 @default(true)
  packageDealsDescription String?
  packageDealsEnabled     Boolean                 @default(false)
  hourlyRateHidden        Boolean                 @default(false)
  contactMessage          String?
  showEmail               Boolean                 @default(false)
  showPhone               Boolean                 @default(false)
  instagramUrl            String?
  facebookUrl             String?
  whatsappUrl             String?
  isBookingEnabled        Boolean                 @default(false)
  minNoticeHours          Int                     @default(48)
  sessionDuration         Int                     @default(60)
  sessionPrice            Float?
  paymentInfo             String?
  paymentMethods          String[]                @default([])
  weeklyAvailability      Availability[]          @relation("WeeklyAvailability")
  availabilityExceptions  AvailabilityException[] @relation("AvailabilityExceptions")
  user                    User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  services                Service[]
  favorites               Favorite[]
  profileViews            ProfileView[]
  enterpriseMemberships   EnterpriseInstructor[]
  followedByEnterprises   InstructorFollow[]

  @@map("instructor_profiles")
}

model Service {
  id           String            @id @default(uuid())
  instructorId String
  name         String
  description  String?
  price        Float
  duration     Int
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  bookings     Booking[]
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@map("services")
}

model Booking {
  id                         String        @id @default(uuid())
  clientId                   String?
  instructorId               String
  serviceId                  String?
  date                       DateTime?
  status                     BookingStatus @default(PENDING)
  notes                      String?
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt
  cancellationReason         String?
  cancelledAt                DateTime?
  cancelledBy                String?
  duration                   Int?
  endTime                    DateTime?
  isManualBlock              Boolean       @default(false)
  isManualBooking            Boolean       @default(false)
  isShortNotice              Boolean       @default(false)
  price                      Float?
  startTime                  DateTime?
  guestEmail                 String?
  guestName                  String?
  guestPhone                 String?
  acknowledgedAt             DateTime?
  hiddenFromClient           Boolean       @default(false)
  
  cancellationToken          String?       @unique
  cancellationTokenExpiresAt DateTime?
  reviewToken                String?       @unique
  reviewTokenExpiresAt       DateTime?
  
  client                     User?         @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Cascade)
  instructorUser             User          @relation("InstructorBookings", fields: [instructorId], references: [id], onDelete: Cascade, map: "bookings_instructor_user_fkey")
  service                    Service?      @relation(fields: [serviceId], references: [id])
  review                     Review?

  @@index([clientId])
  @@index([instructorId])
  @@index([startTime])
  @@index([status])
  
  @@index([cancellationToken])
  @@index([cancellationTokenExpiresAt])
  @@index([reviewToken])
  @@index([reviewTokenExpiresAt])
  @@map("bookings")
}

model Review {
  id              String   @id @default(uuid())
  bookingId       String   @unique
  userId          String?                          // nullable for guest reviews
  rating          Int                              // 1-5
  comment         String?                          // required for 1-3 stars, optional for 4-5
  lowRatingReason String?                          // "no-show" | "unprofessional" | "not-as-described" | "other"
  isGuestReview   Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  booking         Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  user            User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@map("reviews")
}

model Favorite {
  id                   String             @id @default(uuid())
  userId               String
  instructorProfileId  String
  createdAt            DateTime           @default(now())
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  instructorProfile    InstructorProfile  @relation(fields: [instructorProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, instructorProfileId])
  @@index([userId])
  @@index([instructorProfileId])
  @@map("favorites")
}

model EnterpriseFollow {
  id           String             @id @default(uuid())
  followerId   String
  enterpriseId String
  createdAt    DateTime           @default(now())

  follower   User               @relation(fields: [followerId], references: [id], onDelete: Cascade)
  enterprise EnterpriseProfile  @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@unique([followerId, enterpriseId])
  @@index([followerId])
  @@index([enterpriseId])
  @@map("enterprise_follows")
}

model InstructorFollow {
  id                   String             @id @default(uuid())
  enterpriseId         String
  instructorProfileId  String
  createdAt            DateTime           @default(now())

  enterprise          EnterpriseProfile  @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  instructorProfile   InstructorProfile  @relation(fields: [instructorProfileId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, instructorProfileId])
  @@index([enterpriseId])
  @@index([instructorProfileId])
  @@map("instructor_follows")
}

model Availability {
  id           String            @id @default(uuid())
  instructorId String
  dayOfWeek    Int
  startTime    String
  endTime      String
  isActive     Boolean           @default(true)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   InstructorProfile @relation("WeeklyAvailability", fields: [instructorId], references: [id], onDelete: Cascade)

  @@index([instructorId])
  @@map("availability")
}

model AvailabilityException {
  id           String            @id @default(uuid())
  instructorId String
  date         DateTime          @db.Date
  isAvailable  Boolean           @default(false)
  startTime    String?
  endTime      String?
  reason       String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  instructor   InstructorProfile @relation("AvailabilityExceptions", fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([instructorId, date])
  @@index([instructorId])
  @@index([date])
  @@map("availability_exceptions")
}

model VerificationCode {
  id        String   @id @default(uuid())
  email     String
  code      String
  type      String
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email, type, used])
  @@map("verification_codes")
}

model ContactMessage {
  id        String   @id @default(uuid())
  name      String
  email     String
  category  String
  message   String
  createdAt DateTime @default(now())

  @@map("contact_messages")
}

model Notification {
  id        String           @id @default(uuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  data      Json?
  read      Boolean          @default(false)
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read, createdAt])
  @@map("notifications")
}

model ProfileView {
  id                   String             @id @default(uuid())
  userId               String
  instructorProfileId  String
  viewedAt             DateTime           @default(now())
  user                 User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  instructorProfile    InstructorProfile  @relation(fields: [instructorProfileId], references: [id], onDelete: Cascade)

  @@unique([userId, instructorProfileId])
  @@index([userId, viewedAt])
  @@map("profile_views")
}

enum UserRole {
  CLIENT
  INSTRUCTOR
  ADMIN
  ENTERPRISE
}

enum NotificationType {
  FAVORITE
  NEW_BOOKING
  NEW_REVIEW
  BOOKING_CANCELLED
  ENTERPRISE_INVITATION
  ENTERPRISE_INVITATION_ACCEPTED
  NEW_FOLLOWER
  ENTERPRISE_NEWS
}

enum BookingStatus {
  PENDING
  CONFIRMED
  COMPLETED
  CANCELLED
  EXPIRED
}

// ===== ENTERPRISE MODELS =====

enum EnterpriseCategory {
  DANCE_SCHOOL
  GYM
  FITNESS_CLUB
  YOGA_STUDIO
  PILATES_STUDIO
  MARTIAL_ARTS
  SWIMMING_POOL
  PERSONAL_TRAINING_STUDIO
  SPORTS_CENTER
  OTHER
}

enum EnterpriseStatus {
  PENDING
  ACTIVE
  SUSPENDED
  REJECTED
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  REJECTED
  REMOVED
}

model EnterpriseProfile {
  id              String             @id @default(uuid())

  userId          String             @unique
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  status          EnterpriseStatus   @default(PENDING)
  verified        Boolean            @default(false)

  companyName     String
  slug            String             @unique
  shortDescription String?
  description     String?
  email           String?
  phone           String?
  website         String?
  logoUrl         String?
  coverUrl        String?

  facebookUrl     String?
  instagramUrl    String?
  youtubeUrl      String?
  tiktokUrl       String?

  city            String?
  address         String?
  postalCode      String?

  category        EnterpriseCategory @default(OTHER)
  tags            String[]

  amenities       String[]
  openingHours    Json?
  highlights      Json?

  aboutImage      String?
  gallery         String[]
  videos          String[]

  partners        String[]
  certificates    String[]

  businessType    String?
  targetAudience  String[]
  disciplines     String[]
  languages       String[]

  hasParking          Boolean?
  hasShower           Boolean?
  hasLockerRoom       Boolean?
  hasAirConditioning  Boolean?
  hasDisabledAccess   Boolean?
  hasFreeTrial        Boolean?

  pricing         Json?
  faq             Json?

  subscriptionId  String?
  subscriptionStatus String? @default("incomplete")
  subscribedAt    DateTime?
  subscriptionExpiresAt DateTime?

  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  instructors           EnterpriseInstructor[]
  news                  EnterpriseNews[]
  followers             EnterpriseFollow[]
  followedInstructors   InstructorFollow[]

  @@index([status])
  @@index([city])
  @@index([category])
  @@index([slug])
  @@map("enterprise_profiles")
}

model EnterpriseInstructor {
  id              String            @id @default(uuid())

  enterpriseId    String
  instructorId    String

  status          InvitationStatus  @default(PENDING)
  role            String?

  invitedAt       DateTime          @default(now())
  acceptedAt      DateTime?
  rejectedAt      DateTime?
  removedAt       DateTime?

  enterprise      EnterpriseProfile @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)
  instructor      InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([enterpriseId, instructorId])
  @@index([enterpriseId])
  @@index([instructorId])
  @@index([status])
  @@map("enterprise_instructors")
}

model EnterpriseNews {
  id              String            @id @default(uuid())

  enterpriseId    String
  type            String            @default("link")
  url             String
  title           String?
  description     String?
  thumbnailUrl    String?
  platform        String?

  createdAt       DateTime          @default(now())

  enterprise      EnterpriseProfile @relation(fields: [enterpriseId], references: [id], onDelete: Cascade)

  @@index([enterpriseId])
  @@map("enterprise_news")
}

model EnterpriseLead {
  id              String            @id @default(uuid())

  companyName     String
  city            String?
  email           String
  phone           String?
  website         String?
  message         String?
  businessType    String?           // e.g. "dance_school", "gym", "yoga_studio"
  instructorCount String?           // e.g. "1-5", "6-20", "20+"

  status          String            @default("new")
  notes           String?

  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([status])
  @@map("enterprise_leads")
}
